{
  "permissions": {
    "allow": [
      "Bash(npx prisma:*)",
      "Bash(npx tsc:*)",
      "Bash(echo \"Exit: $?\")",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3001)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "Bash(pkill -f \"next dev\")",
      "Bash(curl *)"
    ]
  }
}
